---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { SITE_TITLE } from '../../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../../components/FormattedDate.astro';
import { parseISO, parse } from 'date-fns';

const category = Astro.params.category?.replace(/-/g, ' ') || '';
const decodedCategory = decodeURIComponent(category);

// Get all blog posts
const allPosts = await getCollection('blog');

// Filter posts by category
const categoryPosts = allPosts
	.filter(post => {
		const postCategory = post.data.category?.toLowerCase() || '';
		return postCategory === decodedCategory.toLowerCase();
	})
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function parseBlogDate(dateStr: string | Date) {
	if (dateStr instanceof Date) return dateStr;
	if (typeof dateStr !== 'string') return new Date();
	const isoDate = parseISO(dateStr);
	if (isoDate instanceof Date && !isNaN(isoDate.valueOf())) {
		return isoDate;
	}
	const customDate = parse(dateStr, 'MMM dd yyyy', new Date());
	if (customDate instanceof Date && !isNaN(customDate.valueOf())) {
		return customDate;
	}
	return new Date();
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead 
			title={`${decodedCategory} - ${SITE_TITLE}`} 
			description={`All posts in the ${decodedCategory} category`} 
		/>
		<style>
			main {
				width: 960px;
			}
			
			.hero-section {
				margin-bottom: 3rem;
				padding: 2rem 0;
			}
			
			.hero-section h1 {
				font-size: 2.5rem;
				margin-bottom: 1rem;
				color: var(--black);
			}
			
			.hero-section p {
				font-size: 1.1rem;
				color: var(--gray-dark);
				line-height: 1.6;
			}
			
			.posts-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}
			
			.post-item {
				background: white;
				border: 1px solid var(--gray-light);
				border-radius: 12px;
				padding: 1.5rem;
				margin-bottom: 1.5rem;
				transition: all 0.2s ease;
			}
			
			.post-item:hover {
				transform: translateY(-2px);
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
				border-color: var(--accent);
			}
			
			.post-item a {
				text-decoration: none;
				color: inherit;
				display: block;
			}
			
			.post-title {
				font-size: 1.25rem;
				font-weight: 600;
				color: var(--black);
				margin-bottom: 0.5rem;
			}
			
			.post-description {
				color: var(--gray-dark);
				margin-bottom: 0.75rem;
				line-height: 1.6;
			}
			
			.post-meta {
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
				font-size: 0.9rem;
				color: var(--gray);
			}
			
			.post-tags {
				display: flex;
				gap: 0.5rem;
				flex-wrap: wrap;
				margin-top: 0.75rem;
			}
			
			.tag {
				background: var(--gray-light);
				padding: 0.25rem 0.75rem;
				border-radius: 20px;
				font-size: 0.85rem;
				color: var(--gray-dark);
			}
			
			.empty-state {
				text-align: center;
				padding: 3rem;
				color: var(--gray-dark);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero-section">
				<h1>{decodedCategory}</h1>
				<p>
					{categoryPosts.length} {categoryPosts.length === 1 ? 'post' : 'posts'} in this category
				</p>
			</div>
			
			{categoryPosts.length > 0 ? (
				<ul class="posts-list">
					{
						categoryPosts.map((post) => {
							const link = `/blog/${post.id.replace(/\.mdx?$/, '')}/`;
							return (
								<li class="post-item">
									<a href={link}>
										<h2 class="post-title">{post.data.title}</h2>
										<p class="post-description">{post.data.description}</p>
										<div class="post-meta">
											<time>
												<FormattedDate date={parseBlogDate(post.data.pubDate)} />
											</time>
											{post.data.type && (
												<span>• {post.data.type}</span>
											)}
										</div>
										{post.data.tags && post.data.tags.length > 0 && (
											<div class="post-tags">
												{post.data.tags.map((tag: string) => (
													<span class="tag">{tag}</span>
												))}
											</div>
										)}
									</a>
								</li>
							);
						})
					}
				</ul>
			) : (
				<div class="empty-state">
					<p>No posts found in this category.</p>
					<p><a href="/blog">← Back to all posts</a></p>
				</div>
			)}
		</main>
		<Footer />
	</body>
</html>
