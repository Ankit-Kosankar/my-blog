---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

// Get all blog posts
const allPosts = await getCollection('blog');

// Extract and count tags
const tagCounts = new Map<string, number>();
allPosts.forEach(post => {
	const tags = post.data.tags || [];
	tags.forEach((tag: string) => {
		tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
	});
});

// Sort tags by count (descending), then alphabetically
const sortedTags = Array.from(tagCounts.entries())
	.sort((a, b) => {
		if (b[1] !== a[1]) {
			return b[1] - a[1]; // Sort by count first
		}
		return a[0].localeCompare(b[0]); // Then alphabetically
	});
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead 
			title={`Tags - ${SITE_TITLE}`} 
			description="Browse all blog post tags and topics" 
		/>
		<style>
			main {
				width: 100%;
				max-width: 1200px;
				margin: 0 auto;
				padding: 2.5rem 1.5rem;
				box-sizing: border-box;
			}
			
			.content-wrapper {
				max-width: 100%;
				margin: 0 auto;
				padding: 0;
				box-sizing: border-box;
			}
			
			.hero-section {
				margin-bottom: 3rem;
				padding: 2rem 0;
			}
			
			.hero-section h1 {
				font-size: 2.5rem;
				margin-bottom: 1rem;
				color: var(--black);
			}
			
			.hero-section p {
				font-size: 1.1rem;
				color: var(--gray-dark);
				line-height: 1.6;
			}
			
			.tags-container {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
				gap: 1.5rem;
				margin-top: 2rem;
			}
			
			.tag-card {
				background: white;
				border: 1px solid var(--gray-light);
				border-radius: 12px;
				padding: 1.5rem;
				transition: all 0.2s ease;
				text-decoration: none;
				display: block;
				color: inherit;
			}
			
			.tag-card:hover {
				transform: translateY(-4px);
				box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
				border-color: var(--accent);
			}
			
			.tag-name {
				font-size: 1.1rem;
				font-weight: 600;
				color: var(--black);
				margin-bottom: 0.5rem;
			}
			
			.tag-count {
				font-size: 0.9rem;
				color: var(--gray);
			}
			
			.stats {
				display: flex;
				gap: 2rem;
				margin-top: 2rem;
				padding: 1.5rem;
				background: var(--gray-light);
				border-radius: 12px;
			}
			
			.stat-item {
				text-align: center;
			}
			
			.stat-number {
				font-size: 2rem;
				font-weight: bold;
				color: var(--accent);
				display: block;
			}
			
			.stat-label {
				font-size: 0.9rem;
				color: var(--gray-dark);
				margin-top: 0.25rem;
			}
			
			@media (max-width: 768px) {
				.tags-container {
					grid-template-columns: 1fr;
				}
				
				.stats {
					flex-direction: column;
					gap: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="content-wrapper">
				<div class="hero-section">
					<h1>All Tags</h1>
					<p>
						Browse posts by topic. Click on any tag to see all related posts.
					</p>
				</div>
				
				<div class="stats">
					<div class="stat-item">
						<span class="stat-number">{sortedTags.length}</span>
						<span class="stat-label">Total Tags</span>
					</div>
					<div class="stat-item">
						<span class="stat-number">{allPosts.length}</span>
						<span class="stat-label">Total Posts</span>
					</div>
				</div>
				
				<div class="tags-container">
					{
						sortedTags.map(([tag, count]) => (
							<a href={`/blog/tag/${encodeURIComponent(tag)}/`} class="tag-card">
								<div class="tag-name">{tag}</div>
								<div class="tag-count">{count} {count === 1 ? 'post' : 'posts'}</div>
							</a>
						))
					}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
