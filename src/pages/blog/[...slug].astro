---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { render } from 'astro:content';
import { readFile } from 'fs/promises';
import { join } from 'path';

export const prerender = true;

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	console.log('🔍 Debug: getStaticPaths found', posts.length, 'posts');
	posts.forEach(post => {
		console.log('📝 Debug: Generating path for', post.id, '->', `/blog/${post.id}/`);
	});
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
console.log("The Post is this ",post);
const { Content } = await render(post);

// Calculate reading time from the raw body
function calculateReadingTime(body: string): number {
	const wordsPerMinute = 200;
	// Remove markdown syntax, code blocks, and frontmatter
	const text = body
		.replace(/---[\s\S]*?---/g, '') // Remove frontmatter
		.replace(/```[\s\S]*?```/g, '') // Remove code blocks
		.replace(/`[^`]+`/g, '') // Remove inline code
		.replace(/[#*\[\]()!]/g, '') // Remove markdown syntax
		.replace(/\n+/g, ' ') // Replace newlines with spaces
		.trim();
	const wordCount = text.split(/\s+/).filter(word => word.length > 0).length;
	const readingTime = Math.ceil(wordCount / wordsPerMinute);
	return Math.max(1, readingTime); // At least 1 minute
}

// Get the raw body content for reading time calculation
let readingTime = 1;
try {
	// Try to read the markdown file directly
	const filePath = join(process.cwd(), 'src', 'content', 'blog', post.id);
	const rawBody = await readFile(filePath, 'utf-8');
	readingTime = calculateReadingTime(rawBody);
} catch (error) {
	// Fallback: estimate from description and title
	const fallbackText = `${post.data.title} ${post.data.description}`;
	readingTime = calculateReadingTime(fallbackText);
}
---

<BlogPost {...post.data} readingTime={readingTime}>
	<Content />
</BlogPost>
