<style>
	.about-section {
  margin-bottom: 2rem;
  padding-left: 1rem;
  border-left: 4px solid #3b82f6; /* Tailwind blue-500 */
  border-radius: 8px;
  background-color: #f9fafb;
  padding: 1rem;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 0.5rem;
}

.section-marker {
  width: 10px;
  height: 10px;
  background-color: #3b82f6;
  border-radius: 50%;
  margin-right: 0.5rem;
}

h3 {
  margin: 0;
  font-size: 1.25rem;
}

</style>


